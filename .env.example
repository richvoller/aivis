# Copy to .env.local and fill in. Local Supabase values come from `supabase status`.
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54521"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# DataForSEO Basic auth credentials.
DATAFORSEO_LOGIN=""
DATAFORSEO_PASSWORD=""
DATAFORSEO_USE_MOCK="false"
DATAFORSEO_BASE_URL="https://api.dataforseo.com"
# Parallel LLM calls during collection (max 30, default 8).
DATAFORSEO_CONCURRENCY="8"

# AI keys for brand research (Re-analyze) and suggested prompts.
PERPLEXITY_API_KEY=""
OPENAI_API_KEY=""

# Secret required to trigger the local batch job routes.
JOB_SECRET="local-dev-job-secret-change-me"
